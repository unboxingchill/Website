
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font-sans);background:var(--color-background-tertiary);color:var(--color-text-primary);font-size:14px}
.layout{display:flex;min-height:600px}
.sidebar{width:180px;background:var(--color-background-primary);border-right:0.5px solid var(--color-border-tertiary);padding:1rem 0;flex-shrink:0}
.sidebar-logo{padding:0 1rem 1rem;font-size:14px;font-weight:500;border-bottom:0.5px solid var(--color-border-tertiary);margin-bottom:8px}
.nav-item{display:flex;align-items:center;gap:8px;padding:8px 1rem;font-size:13px;color:var(--color-text-secondary);cursor:pointer;border-left:2px solid transparent}
.nav-item:hover{background:var(--color-background-secondary);color:var(--color-text-primary)}
.nav-item.active{color:var(--color-text-primary);font-weight:500;border-left:2px solid var(--color-text-primary);background:var(--color-background-secondary)}
.nav-item i{font-size:16px}
.content{flex:1;padding:1.5rem;overflow:auto}
.section{display:none}
.section.active{display:block}
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px;margin-bottom:1.5rem}
.metric{background:var(--color-background-secondary);border-radius:var(--border-radius-md);padding:1rem}
.metric-label{font-size:12px;color:var(--color-text-secondary);margin-bottom:4px}
.metric-val{font-size:22px;font-weight:500}
.metric-sub{font-size:11px;color:var(--color-text-tertiary);margin-top:2px}
.card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:1.25rem;margin-bottom:1rem}
.card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.card-title{font-size:14px;font-weight:500}
.btn{background:var(--color-text-primary);color:var(--color-background-primary);border:none;border-radius:var(--border-radius-md);padding:6px 14px;font-size:12px;font-weight:500;cursor:pointer}
.btn-sm{padding:4px 10px;font-size:11px}
.btn-sec{background:transparent;color:var(--color-text-primary);border:0.5px solid var(--color-border-secondary)}
table{width:100%;border-collapse:collapse;font-size:13px;table-layout:fixed}
th{text-align:left;font-weight:500;font-size:12px;color:var(--color-text-secondary);padding:6px 8px;border-bottom:0.5px solid var(--color-border-tertiary)}
td{padding:8px;border-bottom:0.5px solid var(--color-border-tertiary);color:var(--color-text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
tr:last-child td{border:none}
.badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:500}
.badge-success{background:#EAF3DE;color:#3B6D11}
.badge-warning{background:#FAEEDA;color:#854F0B}
.badge-danger{background:#FCEBEB;color:#A32D2D}
.badge-info{background:#E6F1FB;color:#185FA5}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:1rem}
.form-group{display:flex;flex-direction:column;gap:4px}
.form-group label{font-size:12px;color:var(--color-text-secondary)}
.form-group input,.form-group select,.form-group textarea{font-size:13px;padding:7px 10px;border:0.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);background:var(--color-background-primary);color:var(--color-text-primary);width:100%}
.form-group textarea{resize:vertical;min-height:60px}
.modal-wrap{display:none;background:rgba(0,0,0,0.35);min-height:400px;align-items:center;justify-content:center;border-radius:var(--border-radius-lg);margin-bottom:1rem}
.modal-wrap.open{display:flex}
.modal-box{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:1.5rem;width:420px;max-width:95%}
.modal-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem}
.modal-title{font-size:15px;font-weight:500}
.close-btn{background:none;border:none;cursor:pointer;font-size:18px;color:var(--color-text-secondary)}
.stock-bar{height:6px;border-radius:3px;background:var(--color-border-tertiary);margin-top:4px;overflow:hidden}
.stock-fill{height:100%;border-radius:3px}
.alerte{background:#FAEEDA;border:0.5px solid #EF9F27;border-radius:var(--border-radius-md);padding:10px 14px;font-size:13px;color:#854F0B;margin-bottom:1rem;display:flex;align-items:center;gap:8px}
</style>

